@PACKAGE_INIT@

# Compute installation prefix by walking up from lib/cmake/Luau
get_filename_component(_DIR "${CMAKE_CURRENT_LIST_DIR}" DIRECTORY)
get_filename_component(_DIR "${_DIR}" DIRECTORY)
get_filename_component(_DIR "${_DIR}" DIRECTORY)
set(LUAU_INSTALL_PREFIX "${_DIR}")
set(LUAU_INCLUDE_DIR "${LUAU_INSTALL_PREFIX}/include")

# Load exported targets
include("${CMAKE_CURRENT_LIST_DIR}/LuauTargets.cmake")

# Expose a variable for downstream projects
set(LUAU_INCLUDE_DIR "${LUAU_INCLUDE_DIR}" CACHE PATH "Luau include directory")
